# =============================================
# OBE DCCT Agent - Environment Variables
# =============================================

# === LLM API Keys ===
# Gemini
GOOGLE_API_KEY=
# Claude
ANTHROPIC_API_KEY=sk-ant-api03-YourRealClaudeKeyHere

# Grok (tùy chọn)
XAI_API_KEY=

# === Vector Database - Qdrant ===
QDRANT_URL=http://localhost:6333
# Nếu có Qdrant  Nếu không, để trống.
QDRANT_API_KEY=

# === Project Settings ===
DEBUG=True
LOG_LEVEL=INFO

# === Monitoring (tùy chọn) ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=obe-dcct-agent

# === Email (tùy chọn - dùng cho Preview) ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=